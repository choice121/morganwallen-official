# Supabase Edge Function secrets — set these via:
#   supabase secrets set KEY=value --project-ref yxspomuwawzsnsjpqxid

# Gmail SMTP credentials (required for email delivery)
GMAIL_ADDRESS=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional: shared secret to prevent unauthenticated calls to this function.
# Set the same value as VITE_SITE_CALL_SECRET in Cloudflare Pages env vars.
# When set, callers must pass  x-site-secret: <value>  in the request header.
SITE_CALL_SECRET=your-random-secret-here
