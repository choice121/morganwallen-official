# Morgan Wallen site — Crawlers environment variables
# Copy this to .env for local development.
# In GitHub Actions, add these as repository secrets.

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Your Supabase project URL (already known)
SUPABASE_URL=https://yxspomuwawzsnsjpqxid.supabase.co

# Service role key — found in Supabase Dashboard > Settings > API > service_role key
# ⚠️  This key bypasses Row Level Security. Keep it secret. Never commit it.
SUPABASE_SERVICE_KEY=

# ── Spotify (REQUIRED for albums & tracks) ────────────────────────────────────
# Create a free app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── YouTube (REQUIRED for videos & gallery) ───────────────────────────────────
# Enable YouTube Data API v3 at https://console.cloud.google.com
# Create an API key (restrict it to YouTube Data API v3)
YOUTUBE_API_KEY=

# ── ImageKit (OPTIONAL — for uploading gallery photos) ────────────────────────
# Found in ImageKit Dashboard > Developer Options
# If not set, gallery uses YouTube thumbnail URLs directly (still works)
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
